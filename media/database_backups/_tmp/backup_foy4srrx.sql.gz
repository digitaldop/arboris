    visibile boolean CONSTRAINT scuola_evento_calendario_visibile_not_null NOT NULL,
    attivo boolean CONSTRAINT scuola_evento_calendario_attivo_not_null NOT NULL,
    data_creazione timestamp with time zone CONSTRAINT scuola_evento_calendario_data_creazione_not_null NOT NULL,
    data_aggiornamento timestamp with time zone CONSTRAINT scuola_evento_calendario_data_aggiornamento_not_null NOT NULL,
    aggiornato_da_id integer,
    creato_da_id integer,
    categoria_evento_id bigint NOT NULL,
