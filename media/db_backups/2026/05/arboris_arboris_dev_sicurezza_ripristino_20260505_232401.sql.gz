--
-- Name: archivio_storico_anno_scolastico; Type: TABLE; Schema: public; Owner: -
--

CREATE TABLE public.archivio_storico_anno_scolastico (
    id bigint NOT NULL,
    nome_anno_scolastico character varying(50) NOT NULL,
    data_inizio date NOT NULL,
    data_fine date NOT NULL,
    data_archiviazione timestamp with time zone NOT NULL,
    note text NOT NULL,
    totale_snapshot integer NOT NULL,
    totale_studenti integer NOT NULL,
    totale_famiglie integer NOT NULL,
    totale_iscrizioni integer NOT NULL,
    totale_rate integer NOT NULL,
    totale_osservazioni integer NOT NULL,
    totale_documenti integer NOT NULL,
    anno_scolastico_id bigint NOT NULL,
    archiviato_da_id integer,
    CONSTRAINT archivio_storico_anno_scolastico_totale_documenti_check CHECK ((totale_documenti >= 0)),
    CONSTRAINT archivio_storico_anno_scolastico_totale_famiglie_check CHECK ((totale_famiglie >= 0)),
    CONSTRAINT archivio_storico_anno_scolastico_totale_iscrizioni_check CHECK ((totale_iscrizioni >= 0)),
    CONSTRAINT archivio_storico_anno_scolastico_totale_osservazioni_check CHECK ((totale_osservazioni >= 0)),
    CONSTRAINT archivio_storico_anno_scolastico_totale_rate_check CHECK ((totale_rate >= 0)),
    CONSTRAINT archivio_storico_anno_scolastico_totale_snapshot_check CHECK ((totale_snapshot >= 0)),
    CONSTRAINT archivio_storico_anno_scolastico_totale_studenti_check CHECK ((totale_studenti >= 0))
);


